# Copy to .env.local and fill in from your Supabase project
# (Project Settings → API). Only the anon/public key belongs here — never
# the service role key, and never DATABASE_URL/APP_DATABASE_URL or backend
# feature flags (ENABLE_RAG_EMBEDDINGS, ENABLE_ML_CLASSIFIER, etc.) — those
# are backend-only and live in backend/.env instead.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

NEXT_PUBLIC_API_URL=http://localhost:8010/api/v1
