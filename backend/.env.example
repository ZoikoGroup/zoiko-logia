# Variable names only - see ZoikoLogia_Back_End_Architecture_Specification for auth model
# and ZoikoLogia_Kriton_LLM_System_Architecture_Model_Strategy for provider routing.

# Local dev without Docker defaults to SQLite (see core/config.py).
# Via docker-compose, this is set to postgresql+asyncpg://zoiko:zoiko@postgres:5432/zoiko
# DATABASE_URL=postgresql+asyncpg://zoiko:zoiko@localhost:5432/zoiko
DATABASE_URL=

# Optional: a separate non-superuser Postgres role for request-time queries,
# so RLS-based tenant isolation on sources/source_versions actually applies
# (RLS always exempts superusers, and the DATABASE_URL role above is one).
# Auto-provisioned by app/main.py's lifespan if set. Falls back to
# DATABASE_URL when unset — RLS becomes a no-op in that case.
# APP_DATABASE_URL=postgresql+asyncpg://zoiko_app:zoiko_app@localhost:5432/zoiko
APP_DATABASE_URL=

# Loads the real zero-shot risk classifier (cross-encoder/nli-distilroberta-base)
# instead of a fixed 0.5 fallback confidence, which never clears the routing
# threshold — leaving this unset means every query gets routed as "needs
# clarification" regardless of content. Set to true/1/yes.
ENABLE_ML_CLASSIFIER=

# Routes retrieval through the real llama-index + pgvector (Postgres) path
# instead of the keyword_mvp fallback in orchestration/retrieve.py. Requires
# DATABASE_URL to point at a Postgres instance with the pgvector extension
# enabled. Set to true/1/yes.
ENABLE_RAG_EMBEDDINGS=

# TESTING ONLY — forces every query to the LLM route, skipping the real
# HIGH-risk human-review / clarification / refusal policy and the
# post-composition validation degrade (see orchestration/service.py's
# _force_direct_answer()). Does not bypass PII/jailbreak pre-screen blocks.
# Leave unset/false outside of local testing — this disables the actual
# compliance safeguard the system is built around.
FORCE_DIRECT_ANSWER=

JWT_SECRET_KEY=
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# gsk_... (Groq) and/or sk-... (OpenAI) — model_gateway/service.py's
# _select_adapter() prefers Groq, then OpenAI, then falls back to a mock
# provider if neither key is set.
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
AZURE_OPENAI_API_KEY=

# llx-... — enables the LlamaParse cloud fallback parser
# (source_library/parser_service.py) when Docling fails on a document.
LLAMA_CLOUD_API_KEY=

VECTOR_INDEX_URL=
OBJECT_STORAGE_URL=
CELERY_BROKER_URL=
